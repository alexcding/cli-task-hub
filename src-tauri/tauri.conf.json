{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TaskHub",
  "version": "1.0.0",
  "identifier": "tv.accedo.taskhub",
  "build": {
    "frontendDist": "../src/renderer",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "(pkill -f 'target/debug/taskhub'; lsof -ti tcp:3000 | xargs kill -9) 2>/dev/null; TASKHUB_DATA_DIR=\"$HOME/Library/Application Support/tv.accedo.taskhub\" node src/server/app.js",
    "beforeBuildCommand": "bash scripts/build-sidecar.sh"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/alexcding/cli-task-hub/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZFQTdFQzIzQUUxMDQ5NTIKUldSU1NSQ3VJK3luYnZGRlRSOElCNDNWekJxekZzd2RUMTNtQ1FPY3pqcklENmFVWkpjWWFnTWUK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/taskhub-node"],
    "resources": {
      "../src/server": "src/server",
      "../src/shared": "src/shared",
      "../src/renderer": "src/renderer",
      "../node_modules": "node_modules"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
