{
  "name": "taskhub",
  "productName": "TaskHub",
  "version": "1.0.0",
  "description": "Track Jira tickets and GitHub PRs from your Mac menu bar",
  "main": "tray.js",
  "author": "alexcding",
  "license": "ISC",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "./dev.sh",
    "dev:app": "./dev.sh --app",
    "dev:server": "node --watch server.js",
    "dev:tray": "electron .",
    "build": "node scripts/build.js",
    "release": "node scripts/build.js --publish",
    "gen-icon": "node scripts/gen-icon.js",
    "gen-tray-icon": "node scripts/gen-tray-icon.js"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.12.0",
    "dotenv": "^17.4.2",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "express": "^5.2.1",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1"
  }
}
