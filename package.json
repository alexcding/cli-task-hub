{
  "name": "taskhub",
  "productName": "TaskHub",
  "version": "1.0.0",
  "description": "Track Jira tickets and GitHub PRs from your Mac menu bar",
  "main": "tray.js",
  "author": "alexcding",
  "license": "ISC",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "./dev.sh",
    "dev:app": "./dev.sh --app",
    "dev:server": "node --watch server.js",
    "dev:tray": "electron .",
    "build": "node scripts/build.js",
    "release": "node scripts/build.js --publish",
    "gen-icon": "node scripts/gen-icon.js",
    "gen-tray-icon": "node scripts/gen-tray-icon.js"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.12.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "tv.accedo.taskhub",
    "productName": "TaskHub",
    "copyright": "Copyright © 2025 Accedo",
    "afterPack": "scripts/afterPack.js",
    "publish": {
      "provider": "github",
      "owner": "alexcding",
      "repo": "cli-task-hub"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "dmg": {
      "title": "${productName} ${version}",
      "contents": [
        {
          "x": 130,
          "y": 180
        },
        {
          "x": 410,
          "y": 180,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "files": [
      "tray.js",
      "preload.js",
      "server.js",
      "lib/**",
      "public/**",
      "node_modules/**",
      "!node_modules/.cache/**",
      "!**/*.md",
      "!**/*.map"
    ],
    "asarUnpack": [
      "**/node_modules/*node-pty*/**"
    ],
    "extraResources": [
      {
        "from": "build",
        "to": ".",
        "filter": [
          "tray-icon-*.png"
        ]
      }
    ],
    "npmRebuild": false
  }
}
