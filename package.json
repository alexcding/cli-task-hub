{
  "name": "taskhub",
  "productName": "TaskHub",
  "version": "1.0.0",
  "description": "Track Jira tickets and GitHub PRs from your Mac menu bar",
  "main": "src/main/app/main.js",
  "author": "alexcding",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "start": "node src/server/app.js",
    "test": "node --test --test-force-exit 'test/**/*.test.js'",
    "dev": "./dev.sh",
    "dev:app": "./dev.sh --app",
    "dev:tauri": "tauri dev",
    "dev:server": "node --watch src/server/app.js",
    "dev:tray": "electron .",
    "build": "node scripts/build.js",
    "release": "node scripts/build.js --publish",
    "gen-icon": "node scripts/gen-icon.js"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.12.0",
    "dotenv": "^17.4.2",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "express": "^5.2.1",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/cli": "^2.11.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "diff2html": "^3.4.56",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "highlight.js": "^11.11.1"
  }
}
